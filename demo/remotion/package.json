{
  "name": "couplingguard-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Remotion project that renders the couplingguard product demo as MP4 / GIF.",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render CouplingDemo out/couplingguard-demo.mp4",
    "build:gif": "remotion render CouplingDemo out/couplingguard-demo.gif --codec=gif --width=720",
    "build:webm": "remotion render CouplingDemo out/couplingguard-demo.webm --codec=vp8",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0",
    "@remotion/cli": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
